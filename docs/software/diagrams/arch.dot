digraph software_arch {
    rankdir=TB;
    node [shape=box, style=filled, fillcolor=lightblue];
    
    Application [label="Application Layer\nmain.c, tests/"];
    Drivers [label="Driver Layer\nUART, GPIO, Timer"];
    HAL [label="Hardware Abstraction\nsystem.c, memory.c"];
    RegAccess [label="Register Access\nREAD_REG/WRITE_REG"];
    Hardware [label="Hardware\nPeripherals, Memory"];
    
    Application -> Drivers;
    Drivers -> HAL;
    HAL -> RegAccess;
    RegAccess -> Hardware;
    
    {rank=same; Application}
    {rank=same; Drivers}
    {rank=same; HAL}
    {rank=same; RegAccess}
    {rank=same; Hardware}
}